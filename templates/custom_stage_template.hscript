// For static backgrounds

function start(song) {
    var staticBg = new FlxSprite(x, y).loadGraphic(hscriptPath + 'bg.png');
    staticBg.scrollFactor.set(float, float);
    staticBg.antialiasing = true;
    addSprite(staticBg, BEHIND_ALL);
    
    setDefaultZoom(float);
}


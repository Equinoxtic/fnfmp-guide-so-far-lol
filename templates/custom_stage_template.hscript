// for animated backgrounds

function start(song) {
    var animBg = new FlxSprite(x, y).loadGraphic(hscriptPath + 'animBg.png');
    animBg.frames = FlxAtlasFrames.fromSparrow(hscriptPath + 'animBg.png', hscriptPath + 'animBg.xml');
    animBg.animation.addByPrefix('idle', "bg_SHIFT", 0, true);
    animBg.animation.play('idle', true);
    animBg.scrollFactor.set(float, float);
    animBg.antialiasing = true;
    addSprite(animBg, BEHIND_ALL);
}

